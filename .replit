modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Streamlit App"

[[workflows.workflow]]
name = "Streamlit App"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run main.py"
waitForPort = 5000

[deployment]
deploymentTarget = "autoscale"
publicDir = "dist"
run = ["streamlit", "run", "--server.address", "0.0.0.0", "--server.port", "5000", "--server.headless", "true", "--server.enableWebsocketCompression=false", "main.py"]

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
